algoritmo "Primeiro Programa"

var
  numeros: vetor[1..10] de inteiro
  posicao: inteiro
  soma: inteiro
inicio
  para posicao de 1 ate 10 faca
    escreval("Digite o valor do item ", posicao)
    leia(numeros[posicao])
    soma <- soma + numeros[posicao]
  fimpara
  escreval("O valor é: ",soma)




fimalgoritmo

