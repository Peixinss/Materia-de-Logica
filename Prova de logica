questao 1

algoritmo "ContagemRegressiva"
var
  contador: inteiro
  numero: inteiro
inicio
  escreval("Digite um numero: ")
  leia(numero)
  para contador de numero ate 1 passo -1 faca
    escreval("Contagem Regressiva.. ", contador)
  fimpara
fimalgoritmo

questao 2

algoritmo"setup"
var
  itens: vetor[1..5] de caractere
  posicao : inteiro
inicio
  itens[1] <- "Computador"
  itens[2] <- "Televisão"
  itens[3] <- "Mesa"
  itens[4] <- "Cadeira"
  itens[5] <- "Fone"
  para posicao de 1 ate 5 faca
    escreval(itens[posicao])
  fimpara
fimalgoritmo

questao 4

algoritmo "media"
var
  notas: vetor [1..5] de real 
  posicao: inteiro
  media: real
inicio
  para posicao de 1 ate 5 faca
    escreval("coloque a nota ", posicao, " : ")
    leia (notas[posicao])
    media <- media + notas[posicao]
  fimpara
  escreval("A media do aluno é de: ", media: 5)
fimalgoritmo

questao 5
algoritmo "Primeiro Programa"
var
  numero: inteiro
  tabuada: inteiro
inicio
  escreval("coloque o numero que deseja para fazer a tabuada")
  leia (numero)
  para tabuada de 1 ate 10 faca
    escreval(numero,"X", tabuada, "=", numero * tabuada)
  fimpara
fimalgoritmo
