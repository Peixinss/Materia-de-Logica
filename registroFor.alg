// Faça uma contagem regressiva de um dado numero 
// até o numero 1 e mostre para o usuário
algoritmo "ContagemRegressiva"
var
  contador: inteiro
  numero: inteiro
inicio
  escreval("Digite um numero: ")
  leia(numero)
  para contador de numero ate 1 passo -1 faca
    escreval("Contagem Regressiva.. ", contador)
  fimpara
fimalgoritmo






