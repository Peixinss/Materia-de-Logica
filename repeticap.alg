algortimo "Laços de Repetição"
var
    mensagem: caractere

inicio
    escreva("Mensagem: ")
    leia(mensagem)
    enquanto mensagem <> "S" faca
        escreva(mensagem)
        escreva("Próxima mensagem [s para sair]: ")
        leia(mensagem)
    fimenquanto
    escreva("Saiu do laço")
fimalgoritmo